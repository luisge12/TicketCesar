import dotenv from 'dotenv';

// Load environment variables from .env (if present)
dotenv.config();

function parseIntOr(value, fallback) {
  const n = parseInt(value, 10);
  return Number.isNaN(n) ? fallback : n;
}

export const PORT = parseIntOr(process.env.PORT, 3000);
export const HOST = process.env.HOST || '0.0.0.0';
export const SALT_ROUNDS = parseIntOr(process.env.SALT_ROUNDS, 10) || 10;
export const JWT_SECRET = process.env.JWT_SECRET || 'change-me';

export const DB_USER = process.env.DB_USER || '';
export const DB_HOST = process.env.DB_HOST || 'localhost';
export const DB_DATABASE = process.env.DB_DATABASE || '';
export const DB_PASSWORD = process.env.DB_PASSWORD || '';
export const DB_PORT = parseIntOr(process.env.DB_PORT, 5432);

export default {
  PORT,
  HOST,
  SALT_ROUNDS,
  JWT_SECRET,
  DB_USER,
  DB_HOST,
  DB_DATABASE,
  DB_PASSWORD,
  DB_PORT,
};
